{\n  "$schema": "http://json-schema.org/draft-07/schema#",\n  "type": "object",\n  "title": "群聊内容安全审查插件配置",\n  "description": "AstrBot群聊内容安全审查插件的配置文件",\n  "properties": {\n    "enabled_groups": {\n      "description": "启用插件的群号列表",\n      "type": "list",\n      "default": [],\n      "hint": "留空则对所有群生效，否则只对列表中的群生效"\n    },\n    "enable_text_censor": {\n      "description": "是否启用文本审核",\n      "type": "boolean",\n      "default": true\n    },\n    "enable_image_censor": {\n      "description": "是否启用图片审核",\n      "type": "boolean",\n      "default": true\n    },\n    "text_api_providers": {\n      "description": "文本审核API列表",\n      "type": "list",\n      "default": ["baidu"],\n      "hint": "选择用于文本审核的API，可多选。支持: baidu(百度), aliyun(阿里云)。同时选择多个API时，采用交叉审核，任一API检测违规即触发处理。"\n    },\n    "image_api_providers": {\n      "description": "图片审核API列表",\n      "type": "list",\n      "default": ["baidu"],\n      "hint": "选择用于图片审核的API，可多选。支持: baidu(百度), aliyun(阿里云)。同时选择多个API时，采用交叉审核，任一API检测违规即触发处理。"\n    },\n    "api_key": {\n      "description": "百度云API Key",\n      "type": "string",\n      "default": "",\n      "hint": "从百度云控制台获取"\n    },\n    "secret_key": {\n      "description": "百度云Secret Key",\n      "type": "string",\n      "default": "",\n      "hint": "从百度云控制台获取"\n    },\n    "strategy_id": {\n      "description": "百度自定义审核策略ID（可选）",\n      "type": "string",\n      "default": "",\n      "hint": "留空使用默认策略"\n    },\n    "access_key_id": {\n      "description": "阿里云AccessKey ID",\n      "type": "string",\n      "default": "",\n      "hint": "从阿里云RAM控制台获取"\n    },\n    "access_key_secret": {\n      "description": "阿里云AccessKey Secret",\n      "type": "string",\n      "default": "",\n      "hint": "从阿里云RAM控制台获取"\n    },\n    "region": {\n      "description": "阿里云地域",\n      "type": "string",\n      "default": "cn-shanghai",\n      "hint": "默认cn-shanghai，支持cn-beijing, cn-shenzhen, ap-southeast-1等"\n    },\n    "notify_group_id": {\n      "description": "默认通知群ID",\n      "type": "string",\n      "default": "",\n      "hint": "所有无自定义配置的群共用此群发送违规通知"\n    },\n    "admin_id": {\n      "description": "管理员ID",\n      "type": "string",\n      "default": "",\n      "hint": "审核失败时通知此ID的管理员"\n    },\n    "single_user_violation_threshold": {\n      "description": "单人短时间违规次数阈值",\n      "type": "number",\n      "default": 3,\n      "hint": "单人违规达到此次数后触发禁言，设置为0表示不启用"\n    },\n    "group_violation_threshold": {\n      "description": "群内短时间违规次数阈值",\n      "type": "number",\n      "default": 5,\n      "hint": "群内违规达到此次数后触发禁言，设置为0表示不启用"\n    },\n    "time_window": {\n      "description": "统计时间窗口（秒）",\n      "type": "number",\n      "default": 300,\n      "hint": "统计违规次数的时间范围，默认300秒=5分钟"\n    },\n    "mute_duration": {\n      "description": "单人禁言时长（秒）",\n      "type": "number",\n      "default": 86400,\n      "hint": "默认86400秒=1天"\n    },\n    "kick_user": {\n      "description": "是否启用踢人功能",\n      "type": "boolean",\n      "default": false\n    },\n    "kick_user_threshold": {\n      "description": "踢人阈值",\n      "type": "number",\n      "default": 5,\n      "hint": "用户违规达到此次数后被踢出，设置为0表示不启用"\n    },\n    "is_kick_user_and_block": {\n      "description": "是否踢出并拉黑用户",\n      "type": "boolean",\n      "default": false\n    },\n    "group_configs": {\n      "description": "群组自定义配置",\n      "type": "object",\n      "default": {},\n      "additionalProperties": {\n        "type": "object",\n        "properties": {\n          "rule_id": {\n            "description": "规则标识",\n            "type": "string"\n          },\n          "notify_group_id": {\n            "description": "通知群ID",\n            "type": "string"\n          },\n          "single_user_violation_threshold": {\n            "description": "单人违规阈值",\n            "type": "number"\n          },\n          "group_violation_threshold": {\n            "description": "群组违规阈值",\n            "type": "number"\n          },\n          "time_window": {\n            "description": "时间窗口",\n            "type": "number"\n          },\n          "mute_duration": {\n            "description": "禁言时长",\n            "type": "number"\n          },\n          "kick_user_threshold": {\n            "description": "踢人阈值",\n            "type": "number"\n          }\n        }\n      }\n    },\n    "log_level": {\n      "description": "日志级别",\n      "type": "string",\n      "default": "INFO",\n      "hint": "支持DEBUG, INFO, WARNING, ERROR"\n    }\n  },\n  "required": []\n}